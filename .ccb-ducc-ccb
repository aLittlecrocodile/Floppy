#!/bin/zsh
set -e

export DISABLE_BAIDU_CLAUDE_UPDATE="${DISABLE_BAIDU_CLAUDE_UPDATE:-1}"

args=()
while (( $# > 0 )); do
  case "$1" in
    --settings)
      shift
      (( $# > 0 )) && shift
      ;;
    --settings=*)
      shift
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

exec /Users/aooway/.baidu-cc/baidu-cc/bin/ducc "${args[@]}"
